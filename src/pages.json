{
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "今日打卡"
      }
    },
    {
      "path": "pages/rewards/index",
      "style": {
        "navigationBarTitleText": "奖励商城"
      }
    },
    {
      "path": "pages/history/index",
      "style": {
        "navigationBarTitleText": "打卡记录"
      }
    },
    {
      "path": "pages/settings/index",
      "style": {
        "navigationBarTitleText": "设置"
      }
    }
  ],
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "儿童打卡积分",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#FF6B35",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "打卡",
        "iconPath": "static/tab-checkin.png",
        "selectedIconPath": "static/tab-checkin-active.png"
      },
      {
        "pagePath": "pages/rewards/index",
        "text": "奖励",
        "iconPath": "static/tab-reward.png",
        "selectedIconPath": "static/tab-reward-active.png"
      },
      {
        "pagePath": "pages/history/index",
        "text": "记录",
        "iconPath": "static/tab-history.png",
        "selectedIconPath": "static/tab-history-active.png"
      },
      {
        "pagePath": "pages/settings/index",
        "text": "设置",
        "iconPath": "static/tab-settings.png",
        "selectedIconPath": "static/tab-settings-active.png"
      }
    ]
  }
}